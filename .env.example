# CIPHER_KEY là bootstrap root key: canonical base64 của đúng 32 random bytes.
# Các giá trị enc:v1 bên dưới phải được tạo riêng bằng `npm run cipher:encrypt`.
CIPHER_KEY=replace-with-base64-for-exactly-32-random-bytes
RUNTIME_SECRETS_DIR=/tmp/solar-bess-secrets
POSTGRES_DB=solar_bess
POSTGRES_USER=enc:v1:<iv>:<tag>:<ciphertext>
POSTGRES_PASSWORD=enc:v1:<iv>:<tag>:<ciphertext>
DATABASE_URL=enc:v1:<iv>:<tag>:<ciphertext>
REDIS_PASSWORD=enc:v1:<iv>:<tag>:<ciphertext>
RATE_LIMIT_HASH_SECRET=enc:v1:<iv>:<tag>:<ciphertext>
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_KEY_PREFIX=solar-bess
TRUST_PROXY_HOPS=1
COMMAND_RECEIPT_RETENTION_HOURS=24
SCHEDULE_NEAR_CRITICAL_FLOAT_DAYS=5
SCHEDULE_DEFAULT_LOOKAHEAD_DAYS=21
SCHEDULE_IMPORT_MAX_ROWS=5000
SCHEDULE_MAX_ABS_LAG_DAYS=3650
SCHEDULE_ALERT_SCAN_INTERVAL_MS=60000
SCHEDULE_THRESHOLD_VERSION=SCHEDULE_THRESHOLDS_V1
RISK_HIGH_EXPOSURE_THRESHOLD=15
RISK_CRITICAL_EXPOSURE_THRESHOLD=20
RISK_CHANGE_ALERT_SCAN_INTERVAL_MS=60000
RISK_CHANGE_THRESHOLD_VERSION=RISK_CHANGE_THRESHOLDS_V1
JWT_ACCESS_SECRET=enc:v1:<iv>:<tag>:<ciphertext>
JWT_REFRESH_SECRET=enc:v1:<iv>:<tag>:<ciphertext>
JWT_ISSUER=solar-bess-api
JWT_AUDIENCE=solar-bess-web
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
COOKIE_SECURE=false
COOKIE_NAME=refresh_token
COOKIE_PATH=/v1/auth
COOKIE_SAME_SITE=lax
APP_PORT=3000
WORKER_DATABASE_URL_FILE=/run/secrets/database_url
WORKER_DATABASE_HOST_OVERRIDE=postgres
WORKER_REDIS_PASSWORD_FILE=/run/secrets/redis_password
WORKER_REDIS_HOST=redis
WORKER_REDIS_PORT=6379
WORKER_REDIS_DATABASE=0
WORKER_REDIS_CONNECT_TIMEOUT_MS=2000
WORKER_QUEUE_NAME=domain-events
WORKER_DLQ_NAME=domain-events-dlq
WORKER_QUEUE_PREFIX=solar-bess
WORKER_CONSUMER_NAME=foundation-event-ledger-v1
WORKER_HANDLER_VERSION=1.0.0
WORKER_CONSUMER_ATTEMPTS=5
WORKER_CONSUMER_BACKOFF_MS=1000
WORKER_CONCURRENCY=4
WORKER_JOB_LOCK_MS=30000
WORKER_CONSUMPTION_LEASE_MS=60000
WORKER_DATABASE_POOL_SIZE=5
WORKER_DATABASE_CONNECT_TIMEOUT_MS=3000
WORKER_DATABASE_QUERY_TIMEOUT_MS=10000
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=25
OUTBOX_LEASE_MS=30000
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_RETRY_BACKOFF_MS=2000
OUTBOX_PUBLISH_TIMEOUT_MS=5000
WORKER_HEALTH_PORT=3001
WORKER_SHUTDOWN_TIMEOUT_MS=30000
BOOTSTRAP_TENANT_CODE=demo
BOOTSTRAP_TENANT_NAME=Solar BESS Demo
BOOTSTRAP_USER_NAME=Demo Administrator
BOOTSTRAP_USER_EMAIL=enc:v1:<iv>:<tag>:<ciphertext>
BOOTSTRAP_USER_PASSWORD=enc:v1:<iv>:<tag>:<ciphertext>
BOOTSTRAP_ROTATE_PASSWORD=false
