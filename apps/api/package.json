{
  "name": "@solar-bess/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:unit": "jest --config test/config/jest-unit.json --runInBand",
    "test:integration": "jest --config test/config/jest-integration.json --runInBand",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/database/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
    "migration:create": "typeorm migration:create",
    "migration:run:prod": "typeorm migration:run -d dist/database/data-source.js",
    "migration:show:prod": "typeorm migration:show -d dist/database/data-source.js",
    "bootstrap": "ts-node --project tsconfig.json src/database/seeds/bootstrap-user.ts",
    "bootstrap:prod": "node dist/database/seeds/bootstrap-user.js",
    "seed:project-master": "ts-node --project tsconfig.json src/database/seeds/project-master.ts",
    "seed:project-master:prod": "node dist/database/seeds/project-master.js",
    "cipher:encrypt": "ts-node --project tsconfig.json src/modules/cipher/cipher.cli.ts encrypt",
    "env:encrypt": "ts-node --project tsconfig.json src/modules/cipher/cipher.cli.ts migrate-env",
    "secrets:materialize": "ts-node --project tsconfig.json src/modules/cipher/cipher.cli.ts materialize-runtime"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/typeorm": "11.0.3",
    "argon2": "0.44.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "dotenv": "17.4.2",
    "ioredis": "5.11.1",
    "js-yaml": "4.3.0",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeorm": "0.3.30"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.24",
    "@nestjs/testing": "11.1.28",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/jest": "29.5.14",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.10.1",
    "@types/supertest": "6.0.3",
    "jest": "29.7.0",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
