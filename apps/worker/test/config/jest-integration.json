{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../..",
  "testMatch": ["<rootDir>/test/integration/**/*.integration-spec.ts"],
  "transform": { "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/tsconfig.json" }] },
  "testEnvironment": "node",
  "testTimeout": 30000,
  "clearMocks": true
}
