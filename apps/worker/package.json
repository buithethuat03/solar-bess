{
  "name": "@solar-bess/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "outbox:replay": "node dist/replay-failed.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:unit": "jest --config test/config/jest-unit.json --runInBand",
    "test:integration": "npm run test:secrets && jest --config test/config/jest-integration.json --runInBand",
    "test:secrets": "node --experimental-strip-types test/setup/materialize-secrets.ts"
  },
  "dependencies": {
    "bullmq": "5.80.2",
    "ioredis": "5.11.1",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "24.10.1",
    "@types/pg": "8.20.0",
    "jest": "29.7.0",
    "ts-jest": "29.4.11",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
